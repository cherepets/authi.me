<Grid
    x:Class="Authi.App.Maui.UI.CredentialsCollectionView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ui="using:Authi.App.Maui.UI"
    xmlns:viewModels="clr-namespace:Authi.App.Logic.ViewModels;assembly=Authi.App.Logic"
    x:DataType="viewModels:ICredentialsCollectionViewModel"
    SafeAreaEdges="None">
    <ScrollView
        x:Name="ScrollView"
        SafeAreaEdges="Container, None, None, None"
        VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Margin="0,8" BindableLayout.ItemsSource="{Binding Credentials}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="viewModels:CredentialViewModel">
                    <ui:CredentialItemView Margin="16,8" />
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </ScrollView>
    <Grid>
        <Button
            x:Name="AddCredentialsButton"
            Margin="24"
            Clicked="OnAddCredentialsClicked"
            HorizontalOptions="End"
            Style="{StaticResource FloatingActionButtonStyle}"
            Text="{StaticResource AddIcon}"
            VerticalOptions="End" />
    </Grid>
</Grid>
